{
  "name": "vonosan-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun test",
    "lint": "bun run --filter='*' lint",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "@types/node": "25.5.2",
    "fast-check": "4.6.0",
    "typescript": "5.8.3"
  }
}
