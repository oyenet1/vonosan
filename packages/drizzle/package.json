{
  "name": "@vonosan/drizzle",
  "version": "0.2.0",
  "type": "module",
  "description": "Vono Drizzle ORM integration — mixins, soft deletes, scopes, seed helpers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyenet1/vonosan.git",
    "directory": "packages/drizzle"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.0.1",
    "postgres": "3.4.7"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.44.0",
    "vonosan": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "@types/node": "25.5.2",
    "drizzle-orm": "0.44.5",
    "typescript": "5.8.3",
    "vonosan": "workspace:*"
  }
}
