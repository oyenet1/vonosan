{
  "name": "@vonosan/drizzle",
  "version": "0.1.0",
  "type": "module",
  "description": "Vono Drizzle ORM integration — mixins, soft deletes, scopes, seed helpers",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.44.0",
    "vonosan": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "drizzle-orm": "0.44.5",
    "typescript": "5.8.3",
    "vonosan": "workspace:*"
  }
}
