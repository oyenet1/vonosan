{
  "name": "@vono/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Vono Artisan-style scaffolding CLI",
  "bin": {
    "vono": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "kolorist": "latest",
    "execa": "latest",
    "glob": "latest",
    "fast-glob": "latest"
  },
  "peerDependencies": {
    "vono": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "fast-check": "^4.6.0",
    "typescript": "latest",
    "vono": "workspace:*"
  }
}
