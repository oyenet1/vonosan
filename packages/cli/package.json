{
  "name": "@vonosan/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Vono Artisan-style scaffolding CLI",
  "bin": {
    "vono": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@clack/prompts": "0.11.0",
    "execa": "9.5.2",
    "fast-glob": "3.3.3",
    "glob": "11.0.2",
    "kolorist": "1.8.0"
  },
  "peerDependencies": {
    "vonosan": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "fast-check": "4.6.0",
    "typescript": "5.8.3",
    "vonosan": "workspace:*"
  }
}
