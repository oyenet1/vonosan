{
  "name": "vonosan",
  "version": "0.2.0",
  "type": "module",
  "description": "Vonosan core runtime — config, composables, SSR helpers, Vite plugin",
  "license": "MIT",
  "author": "Bowofade Oyerinde",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyenet1/vonosan.git",
    "directory": "packages/vonosan"
  },
  "homepage": "https://github.com/oyenet1/vonosan#readme",
  "keywords": [
    "vonosan",
    "vue",
    "vite",
    "ssr",
    "framework",
    "hono",
    "fullstack"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite/index.js",
      "types": "./dist/vite/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/__tests__"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@unhead/vue": ">=2.0.0",
    "drizzle-orm": ">=0.44.0",
    "hono": ">=4.8.0",
    "pinia": ">=3.0.0",
    "vue": ">=3.5.0",
    "vue-router": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@unhead/vue": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "pinia": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "@types/node": "25.5.2",
    "@unhead/ssr": "2.0.10",
    "@unhead/vue": "2.0.10",
    "drizzle-orm": "0.44.5",
    "hono": "4.8.10",
    "pinia": "3.0.2",
    "typescript": "5.8.3",
    "vue": "3.5.13",
    "vue-router": "5.0.0",
    "zod": "4.1.8"
  }
}
