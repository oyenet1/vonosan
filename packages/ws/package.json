{
  "name": "@vonosan/ws",
  "version": "0.1.0",
  "type": "module",
  "description": "Vono WebSocket module — adapter-based (native, socket.io, CF)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyenet1/vonosan.git",
    "directory": "packages/ws"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "hono": ">=4.8.0",
    "vue": ">=3.5.0",
    "vonosan": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "@types/node": "25.5.2",
    "hono": "4.8.10",
    "typescript": "5.8.3",
    "vue": "3.5.13",
    "vonosan": "workspace:*"
  }
}
